# WikiSTEM | Javier Fernando Vega Alamo | CS50x 2026
# Copy to .env — fill all values — NEVER commit .env to Git

# Which config to load: 'development' or 'production'
# v4 — APP_ENV replaces deprecated FLASK_ENV. Flask 3.x no longer reads FLASK_ENV
# for debug mode, so we read our own variable instead.
APP_ENV=development

# Local-dev only (audit finding G6): APP_ENV controls which config class loads,
# but Flask's CLI reloader + interactive debugger key off FLASK_DEBUG. Set this
# to 1 for `flask run` in development. LEAVE IT UNSET / 0 in production — never
# expose the Werkzeug debugger on a live site (it allows arbitrary code exec).
FLASK_DEBUG=1

# Flask session signing key
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex

# ── Admin seed (used ONLY by init_db.py) ───────────────────────────────────
# The admin account is created from these on first init. ADMIN_PASSWORD has NO
# default — init_db.py refuses to seed the admin unless you set one (8-128 chars).
# Change it before deploying and enroll 2FA immediately after first login.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@wikistem.edu.pe
ADMIN_PASSWORD=replace_with_strong_admin_password

# Google Gemini API — free at aistudio.google.com (no credit card required)
GEMINI_API_KEY=replace_with_gemini_key

# Fernet symmetric encryption key for PII (email, bio)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# ── Outbound email (sign-up verification) ──────────────────────────────────
# Sign-up uses a verify-then-create flow: the app emails an activation link and
# only creates the account when the user clicks it. Sending goes through a
# DEDICATED Gmail mailbox over SMTP. MAIL_PASSWORD is a Gmail *App Password*
# (16 chars), NOT the account password — generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification on
# that Google account). Gmail rewrites the From header to MAIL_USERNAME, so the
# sender shown is always the authenticated mailbox.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=wikistem.noreply@gmail.com
MAIL_PASSWORD=replace_with_gmail_app_password
MAIL_DEFAULT_SENDER=wikistem.noreply@gmail.com
